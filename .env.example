PORT=3000
TIME_ZONE=Europe/Rome
SESSION_SECRET=change-this-secret
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=Admin123!
INITIAL_ADMIN_NAME=Amministratore
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SCHEMA=public

# Recommended if available in your project
SUPABASE_SECRET_KEY=

# Legacy alternative if you do not have a secret key yet
SUPABASE_SERVICE_ROLE_KEY=

ALLOW_MOCK_DELIVERY=true
REMINDER_RETRY_MINUTES=15
APP_CREDENTIALS_SECRET=
META_GRAPH_VERSION=v23.0

# Email piattaforma via Resend (opzionale se ogni ramo usa la propria mailbox SMTP)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Appuntamenti <noreply@example.com>

# SMS via Twilio e fallback WhatsApp della piattaforma
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Wallet Stripe per ricaricare il credito del ramo
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WALLET_CURRENCY=EUR
STRIPE_WALLET_MIN_TOPUP=10
STRIPE_WALLET_MAX_TOPUP=1000
STRIPE_WALLET_TOPUP_OPTIONS=25,50,100
